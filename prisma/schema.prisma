generator client {
  provider            = "prisma-client"
  output              = "./generated/"
  importFileExtension = "ts"
  moduleFormat        = "esm"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id            String   @id @unique
  titleEnglish  String
  titleJapanese String
  length        String
  description   String
  releaseDate   DateTime
  nicoId        String?
  youtubeId     String?
  coverArt      String
  themeColor    String?

  credits     Json?
  lyrics      Lyrics[]
  albumTracks AlbumTrack[]

  @@index([releaseDate(sort: Desc)], name: "song_release_date_idx")
  @@index([titleEnglish], name: "song_title_english_idx")
  @@index([titleJapanese], name: "song_title_japanese_idx")
}

model Lyrics {
  songId     String
  language   String
  translator String?
  lines      String[]

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([songId, language])
  @@index([songId])
}

model Album {
  id            String    @id @unique
  titleEnglish  String
  titleJapanese String
  releaseDate   DateTime
  type          AlbumType
  coverArt      String

  credits Json?
  tracks  AlbumTrack[]

  @@index([releaseDate(sort: Desc)], name: "album_release_date_idx")
  @@index([type], name: "album_type_idx")
}

model AlbumTrack {
  albumId      String
  songId       String
  trackNumber  Int
  isBonusTrack Boolean @default(false)

  album Album @relation(fields: [albumId], references: [id])
  song  Song  @relation(fields: [songId], references: [id])

  @@id([albumId, songId])
  @@unique([albumId, trackNumber])
  @@index([albumId, trackNumber], name: "album_track_order_idx")
}

enum AlbumType {
  single
  ep
  album
}

model ExternalLink {
  id           Int    @id @default(autoincrement())
  relationId   String
  relationType String

  type        ExternalLinkType
  value       String
  title       String?
  description String?
  createdAt   DateTime         @default(now())

  @@index([relationType, relationId], name: "external_link_relation_idx")
  @@index([type], name: "external_link_type_idx")
}

enum ExternalLinkType {
  youtubeVideo
  nicoVideo
  link
  embed
}
