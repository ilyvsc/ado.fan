generator client {
  provider            = "prisma-client"
  output              = "./generated/"
  importFileExtension = "ts"
  moduleFormat        = "esm"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id            String       @id @unique
  titleEnglish  String
  titleJapanese String
  length        String
  year          Int
  releaseDate   DateTime
  description   String
  nicoId        String?
  youtubeId     String?
  coverArt      String
  albumTracks   AlbumTrack[]
  Section       Section[]
  themeColor    String?
  lyrics        Lyrics[]

  @@index([releaseDate(sort: Desc)], name: "song_release_date_idx")
  @@index([year], name: "song_year_idx")
}

model Lyrics {
  songId         String @id @unique
  lyricsJapanese String
  lyricsRomaji   String
  lyricsEnglish  String
  song           Song   @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId], name: "lyrics_song_id_idx")
}

model Album {
  id            String       @id @unique
  titleEnglish  String
  titleJapanese String
  releaseDate   DateTime
  type          AlbumType
  coverArt      String
  tracks        AlbumTrack[]

  @@index([releaseDate(sort: Desc)], name: "album_release_date_idx")
  @@index([type], name: "album_type_idx")
}

model AlbumTrack {
  albumId      String
  songId       String
  trackNumber  Int
  isBonusTrack Boolean @default(false)
  album        Album   @relation(fields: [albumId], references: [id])
  song         Song    @relation(fields: [songId], references: [id])

  @@id([albumId, songId])
  @@unique([albumId, trackNumber])
  @@index([albumId, trackNumber], name: "album_track_order_idx")
}

model Section {
  name   String
  songId String
  song   Song   @relation(fields: [songId], references: [id])

  @@id([name, songId])
  @@index([songId])
}

enum AlbumType {
  single
  ep
  album
}
