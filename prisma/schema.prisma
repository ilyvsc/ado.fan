generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model Song {
  id             String        @id
  titleEnglish   String
  titleJapanese  String
  lyricsJapanese String        @default("")
  lyricsRomaji   String        @default("")
  lyricsEnglish  String        @default("")
  length         String
  year           Int
  releaseDate    DateTime
  description    String
  nicoId         String?
  youtubeId      String?
  coverArt       String
  albumTracks    AlbumTrack[]
  SectionItem    SectionItem[]
  themeColor     String?

  @@index([releaseDate(sort: Desc)], name: "song_release_date_idx")
  @@index([year], name: "song_year_idx")
}

model Album {
  id            String       @id
  titleEnglish  String
  titleJapanese String
  releaseDate   DateTime
  type          AlbumType
  coverArt      String
  tracks        AlbumTrack[]

  @@index([releaseDate(sort: Desc)], name: "album_release_date_idx")
  @@index([type], name: "album_type_idx")
}

model AlbumTrack {
  albumId      String
  songId       String
  trackNumber  Int
  isBonusTrack Boolean @default(false)
  album        Album   @relation(fields: [albumId], references: [id])
  song         Song    @relation(fields: [songId], references: [id])

  @@id([albumId, songId])
  @@unique([albumId, trackNumber])
  @@index([albumId, trackNumber], name: "album_track_order_idx")
}

model Section {
  id    String        @id @unique
  items SectionItem[]
}

model SectionItem {
  sectionId String
  songId    String
  order     Int
  section   Section @relation(fields: [sectionId], references: [id])
  song      Song    @relation(fields: [songId], references: [id])

  @@id([sectionId, songId])
  @@unique([sectionId, order])
  @@index([songId], name: "section_item_song_idx")
  @@index([sectionId, order], name: "section_item_order_idx")
}

enum AlbumType {
  single
  ep
  album
}
